# Production Environment Variables

# Telegram configuration
TELEGRAM_BOT_TOKEN=your_production_bot_token_here
BOT_NAME=your_production_bot_username_here
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Application configuration
NODE_ENV=production
PORT=3000

# Database configurations
POSTGRES_USER=stock_sniper
POSTGRES_PASSWORD=generate_a_very_long_secure_password_here
POSTGRES_DB=stock_sniper_prod

# Database connection URL for Prisma (must match the database credentials above and use host "db")
DATABASE_URL="postgresql://stock_sniper:generate_a_very_long_secure_password_here@db:5432/stock_sniper_prod?schema=public"

# Affiliate links (optional)
AFFILIATE_LINK_PREFIX_BRAIN=
AFFILIATE_LINK_PREFIX_ALLO=
AFFILIATE_LINK_PREFIX_MOYO=
AFFILIATE_LINK_PREFIX_COMFY=
AFFILIATE_LINK_PREFIX_FOXTROT=
